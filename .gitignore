# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
ehthumbs.db
Thumbs.db

# ---------------------------------------------------------------------------
# Editors / IDEs
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# ---------------------------------------------------------------------------
# Agent config (registered per-user at local scope, never committed)
# ---------------------------------------------------------------------------
.mcp.json

# ===========================================================================
# Python (model/, app/backend/)
# ===========================================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test / coverage / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/

# Package managers (uv / poetry / pip)
# NOTE: keep lockfiles committed — do NOT ignore uv.lock / poetry.lock
pip-log.txt
pip-wheel-metadata/

# Runtime
*.db
*.sqlite3
instance/

# ---------------------------------------------------------------------------
# model/ — binary data/weights/artifacts (not code)
# ---------------------------------------------------------------------------
model/data/*
!model/data/.gitkeep
model/weights/*
!model/weights/.gitkeep
model/artifacts/*
!model/artifacts/.gitkeep

# CoreML EP on-disk compile cache (built next to the ONNX weights at runtime)
.coreml_cache/

# ===========================================================================
# Node / frontend (app/frontend/)
# ===========================================================================
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
.nuxt/
.cache/
.parcel-cache/
.vite/

# Testing
coverage/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Framework / tooling caches
.turbo/
.eslintcache
.stylelintcache

# Local env for Vite / CRA / Next
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
tmp/
temp/
*.pid
*.seed

# Runtime capture output (datasets/video entries written by the dashboard)
data-collection/dashboard/captures/
